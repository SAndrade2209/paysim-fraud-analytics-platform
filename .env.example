# ─── Snowflake ────────────────────────────────────────────────────────────────
SNOWFLAKE_USER=YOUR_SNOWFLAKE_USERNAME
SNOWFLAKE_ACCOUNT=YOUR_ACCOUNT_IDENTIFIER   # e.g. xy12345.us-east-2.aws
SNOWFLAKE_WAREHOUSE=FRAUD_WH
SNOWFLAKE_DATABASE=FRAUD_DB
RAW_SNOWFLAKE_SCHEMA=RAW
SNOWFLAKE_PASSWORD=YOUR_SNOWFLAKE_PASSWORD
SNOWFLAKE_PRIVATE_KEY_PATH=/absolute/path/to/secrets/snowflake_key.p8

# ─── Google Cloud Platform ────────────────────────────────────────────────────
GCP_BUCKET=YOUR_GCS_BUCKET_NAME             # e.g. fintech-fraud-platform-paysim-landing
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/secrets/fraud-loader-key.json

# ─── Spark ────────────────────────────────────────────────────────────────────
SPARK_GCP_JAR=/absolute/path/to/ingestion/jars/gcs-connector.jar

# ─── Airflow ──────────────────────────────────────────────────────────────────
AIRFLOW_PASSWORD=YOUR_AIRFLOW_ADMIN_PASSWORD
AIRFLOW_HOME=/absolute/path/to/paysim-fraud-analytics-platform/airflow
AIRFLOW__CORE__DAGS_FOLDER=/absolute/path/to/paysim-fraud-analytics-platform/orchestration/dags

