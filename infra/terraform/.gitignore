# Terraform state — never commit
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# Real variable values — never commit
terraform.tfvars

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc

